# ── Databricks credentials ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.

# Your Databricks workspace URL (from browser address bar)
DATABRICKS_HOST=https://adb-xxxx.xx.azuredatabricks.net

# HTTP path for your SQL warehouse
# Found at: Databricks workspace → SQL Warehouses → your warehouse → Connection Details tab
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxx

# Personal Access Token
# Found at: Databricks workspace → Settings → Developer → Access Tokens → Generate New Token
# Rotate every 90 days.
DATABRICKS_TOKEN=dapixxxxxxxxxxxxxxxx

# ── Azure Storage (for direct Delta Lake reads via delta-rs) ──────────────────
# Only needed if using scripts/databricks_connector.py with Delta table direct reads.
# Leave blank if using the SQL connector only.

AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=

# ── Optional: default catalog and schema ─────────────────────────────────────
# If set, the data-fetcher will use these as defaults for unqualified table names.
DATABRICKS_DEFAULT_CATALOG=main_catalog
DATABRICKS_DEFAULT_SCHEMA=super_analytics
