# Data — never commit raw datasets or credentials
data/*
!data/.gitkeep
!data/README.md
data/reference/
data/processed/

# Outputs — keep folder structure, ignore content
outputs/*
!outputs/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.coverage

# IDEs
.vscode/
.idea/
*.swp
.DS_Store

# Claude Code local state
.claude/projects/
.claude/sessions/
.agents/
.codex/

# Secrets
.env
.env.local
*.pem
*.key

# Notebooks
.ipynb_checkpoints/
docs/manager_update.md
